{
  "name": "@johnnywu/pi-filechanges",
  "version": "1.0.1",
  "description": "Tracks files changed by pi via edit and write tools, with diff inspection and revert support",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "files": [
    "extensions/",
    "README.md",
    "package.json",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jwu/pi-filechanges.git"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bun tsc --noEmit --ignoreDeprecations 6.0",
    "format": "prettier --write '**/*.ts'",
    "format:check": "prettier --check '**/*.ts'",
    "prepare": "[ -d .git ] && simple-git-hooks || true",
    "release": "GH_TOKEN=$(gh auth token) semantic-release --no-ci",
    "release:dry": "GH_TOKEN=$(gh auth token) semantic-release --no-ci --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "repositoryUrl": "https://github.com/jwu/pi-filechanges.git",
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "bun prettier --check '**/*.ts' && bun test",
    "commit-msg": "bun commitlint --edit \"$1\""
  },
  "dependencies": {
    "diff": "^5.2.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/diff": "^5.2.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  }
}
