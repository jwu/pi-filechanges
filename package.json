{
  "name": "@johnnywu/pi-filechanges",
  "version": "1.0.0",
  "description": "Tracks files changed by pi via edit and write tools, with diff inspection and revert support",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "files": [
    "extensions/",
    "README.md",
    "package.json",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnnywu/pi-filechanges.git"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --experimental-strip-types --test \"extensions/__tests__/*.test.ts\"",
    "release": "semantic-release"
  },
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/git"
    ]
  },
  "dependencies": {
    "diff": "^5.2.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "semantic-release": "^25.0.3"
  }
}
